# Server-side only. Never expose this value through a NEXT_PUBLIC_ variable.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# Generate at least 32 random characters. Never reuse a public example value.
SESSION_SECRET="REPLACE_WITH_A_RANDOM_SECRET_OF_AT_LEAST_32_CHARACTERS"

# Used only by the one-time server-side `npm run user:create` command.
# Set these temporarily in the process environment; do not store a real password here.
MIJNPLANNING_BOOTSTRAP_EMAIL="peter@example.invalid"
MIJNPLANNING_BOOTSTRAP_PASSWORD="REPLACE_WITH_A_STRONG_PASSWORD_OF_AT_LEAST_15_CHARACTERS"
